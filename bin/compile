#!/usr/bin/env bash
# Custom monorepo buildpack that copies APP_BASE to root while preserving
# Yarn workspace infrastructure (packages/, yarn.lock, .yarnrc.yml, .yarn/).
#
# Drop-in replacement for https://github.com/lstoll/heroku-buildpack-monorepo
# that supports workspace:* protocol dependencies.
#
# Required config var:
#   APP_BASE - the subdirectory containing the app (e.g., "numero_server")

set -eo pipefail

BUILD_DIR=$1
CACHE_DIR=$2
ENV_DIR=$3

# Read APP_BASE from env
if [ -f "$ENV_DIR/APP_BASE" ]; then
  APP_BASE=$(cat "$ENV_DIR/APP_BASE")
fi

if [ -z "$APP_BASE" ]; then
  echo "       ERROR: APP_BASE is not set. Set it to the subdirectory of your app." >&2
  exit 1
fi

echo "-----> Monorepo workspace app detected (APP_BASE=$APP_BASE)"

(
  cd "$BUILD_DIR"

  if [ ! -d "$APP_BASE" ]; then
    echo "       ERROR: APP_BASE directory '$APP_BASE' does not exist." >&2
    exit 1
  fi

  # --- Stage 1: Save workspace infrastructure to a temp location ---
  WORKSPACE_STAGE="$(mktemp -d)"

  if [ -d "packages" ]; then
    echo "       Saving packages/ directory..."
    cp -R "packages" "$WORKSPACE_STAGE/"
  fi

  if [ -f "yarn.lock" ]; then
    echo "       Saving yarn.lock..."
    cp "yarn.lock" "$WORKSPACE_STAGE/"
  fi

  if [ -f ".yarnrc.yml" ]; then
    echo "       Saving .yarnrc.yml..."
    cp ".yarnrc.yml" "$WORKSPACE_STAGE/"
  fi

  if [ -d ".yarn" ]; then
    echo "       Saving .yarn/ directory..."
    cp -R ".yarn" "$WORKSPACE_STAGE/"
  fi

  # Save root package.json so we can detect the Yarn version after Stage 2 wipes it
  if [ -f "package.json" ]; then
    cp "package.json" "$WORKSPACE_STAGE/root-package.json"
  fi

  # --- Stage 2: Copy APP_BASE to root (same as lstoll/heroku-buildpack-monorepo) ---
  APP_STAGE="$(mktemp -d)"
  shopt -s dotglob

  cp -R "${APP_BASE}/." "$APP_STAGE/" 2>/dev/null
  rm -rf *
  cp -R "$APP_STAGE/." . 2>/dev/null

  echo "       Copied $APP_BASE to root of app successfully"

  # --- Stage 3: Restore workspace infrastructure ---
  if [ -d "$WORKSPACE_STAGE/packages" ]; then
    cp -R "$WORKSPACE_STAGE/packages" .
    echo "       Restored packages/ directory"
  fi

  if [ -f "$WORKSPACE_STAGE/yarn.lock" ]; then
    cp "$WORKSPACE_STAGE/yarn.lock" .
    echo "       Restored yarn.lock"
  fi

  if [ -f "$WORKSPACE_STAGE/.yarnrc.yml" ]; then
    cp "$WORKSPACE_STAGE/.yarnrc.yml" .
    echo "       Restored .yarnrc.yml"
  fi

  if [ -d "$WORKSPACE_STAGE/.yarn" ]; then
    cp -R "$WORKSPACE_STAGE/.yarn" .
    echo "       Restored .yarn/ directory"
  fi

  # --- Detect Yarn version from the monorepo root package.json (saved in Stage 1) ---
  # The root packageManager field is the source of truth for the Yarn version.
  YARN_VERSION=""
  if [ -f "$WORKSPACE_STAGE/root-package.json" ] 2>/dev/null; then
    YARN_VERSION=$(python3 -c "
import json, sys
try:
    with open('$WORKSPACE_STAGE/root-package.json') as f:
        pm = json.load(f).get('packageManager', '')
    if pm.startswith('yarn@'):
        print(pm.replace('yarn@', ''))
except Exception:
    pass
" 2>/dev/null)
  fi
  if [ -z "$YARN_VERSION" ]; then
    # Fallback: try to read from the .yarn/releases directory
    YARN_VERSION=$(ls .yarn/releases/yarn-*.cjs 2>/dev/null | sed 's/.*yarn-\(.*\)\.cjs/\1/' | head -1)
  fi
  if [ -z "$YARN_VERSION" ]; then
    echo "       WARNING: Could not detect Yarn version, defaulting to 4.13.0" >&2
    YARN_VERSION="4.13.0"
  fi
  echo "       Detected Yarn version: $YARN_VERSION"

  # --- Stage 4: Patch package.json and .yarnrc.yml for Heroku ---
  # Uses python3 (available on Heroku-24 stack) since node isn't installed yet.
  if python3 -c "
import json, sys, os, re

yarn_version = '$YARN_VERSION'

# --- Patch package.json ---
pkg_path = 'package.json'
if os.path.exists(pkg_path):
    with open(pkg_path) as f:
        pkg = json.load(f)

    # Add workspaces field if packages/ directory was restored
    if os.path.isdir('packages') and 'workspaces' not in pkg:
        pkg['workspaces'] = ['packages/*']

    # Add packageManager so Heroku Node.js buildpack uses Yarn 4 via Corepack
    if 'packageManager' not in pkg:
        pkg['packageManager'] = 'yarn@' + yarn_version

    with open(pkg_path, 'w') as f:
        json.dump(pkg, f, indent=2)
        f.write('\n')

# --- Patch .yarnrc.yml ---
# Remove yarnPath to avoid conflict with packageManager (Corepack handles it).
yarnrc_path = '.yarnrc.yml'
if os.path.exists(yarnrc_path):
    with open(yarnrc_path) as f:
        content = f.read()
    content = re.sub(r'^yarnPath:.*\n?', '', content, flags=re.MULTILINE)
    with open(yarnrc_path, 'w') as f:
        f.write(content)

sys.exit(0)
" 2>/dev/null; then
    echo "       Patched package.json and .yarnrc.yml for Heroku"
  else
    echo "       WARNING: python3 not available, falling back to sed" >&2
    if ! grep -q '"workspaces"' package.json && [ -d "packages" ]; then
      sed -i 's/^{$/{\n  "workspaces": ["packages\/*"],/' package.json
    fi
    if ! grep -q '"packageManager"' package.json; then
      sed -i "s/^{$/{\n  \"packageManager\": \"yarn@${YARN_VERSION}\",/" package.json
    fi
    sed -i '/^yarnPath:/d' .yarnrc.yml 2>/dev/null
    echo "       Patched via sed"
  fi

  # --- Stage 5: Update yarn.lock for reduced workspace set ---
  # The root yarn.lock references ALL workspaces, but Heroku only has
  # APP_BASE + packages/*. We must sync the lockfile here so the Node.js
  # buildpack's --immutable check passes.
  YARN_RELEASE=".yarn/releases/yarn-${YARN_VERSION}.cjs"
  if [ -f "yarn.lock" ] && [ -f "$YARN_RELEASE" ]; then
    echo "       Syncing yarn.lock for reduced workspace set..."

    # Export config vars that Yarn needs (e.g., NPM_AUTH_TOKEN for @numeroai scope)
    if [ -d "$ENV_DIR" ]; then
      for key in NPM_AUTH_TOKEN GITHUB_TOKEN; do
        if [ -f "$ENV_DIR/$key" ]; then
          export "$key=$(cat "$ENV_DIR/$key")"
        fi
      done
    fi

    # Download a temporary Node.js to run the vendored Yarn 4
    NODE_VERSION="22.22.0"
    NODE_DIR="$(mktemp -d)"
    curl -sL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-x64.tar.gz" \
      | tar xz -C "$NODE_DIR" --strip-components=1

    # Update only the lockfile — no packages are downloaded or linked
    "$NODE_DIR/bin/node" "$YARN_RELEASE" install --mode=update-lockfile 2>&1 \
      | sed 's/^/       /'

    rm -rf "$NODE_DIR"
    echo "       yarn.lock synced successfully"
  else
    if [ -f "yarn.lock" ]; then
      echo "       WARNING: Vendored Yarn release not found at $YARN_RELEASE, skipping lockfile sync" >&2
    fi
  fi

  # Cleanup
  rm -rf "$APP_STAGE" "$WORKSPACE_STAGE"
)

echo "-----> Monorepo workspace buildpack complete"
